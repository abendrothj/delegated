{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentauth.dev/schemas/shared-trust-claims.schema.json",
  "title": "SharedTrustClaims",
  "type": "object",
  "required": [
    "spec_version",
    "kind",
    "agent_id",
    "delegator_id",
    "audience",
    "action",
    "delegation_token"
  ],
  "properties": {
    "spec_version": { "type": "string", "const": "0.1" },
    "kind": { "type": "string", "const": "SharedTrustClaims" },
    "request_id": { "type": "string", "minLength": 1 },
    "agent_id": { "type": "string", "minLength": 1 },
    "delegator_id": { "type": "string", "minLength": 1 },
    "audience": { "type": "string", "minLength": 1 },
    "action": { "type": "string", "minLength": 1 },
    "resource": { "type": "string", "minLength": 1 },
    "runtime_context": {
      "$ref": "request-envelope.schema.json#/properties/runtime_context"
    },
    "identity_document": {
      "$ref": "agent-identity-document.schema.json"
    },
    "delegation_token": {
      "$ref": "delegation-token.schema.json"
    }
  },
  "additionalProperties": true
}
