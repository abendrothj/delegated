{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentauth.dev/schemas/issuer-metadata.schema.json",
  "title": "IssuerMetadata",
  "type": "object",
  "required": [
    "issuer",
    "jwks_uri",
    "registry_uri",
    "resolution_uri",
    "revocation_uri",
    "approval_uri",
    "supported_signature_algorithms",
    "supported_protocols",
    "supported_profiles",
    "spec_version"
  ],
  "properties": {
    "issuer": { "type": "string", "minLength": 1 },
    "jwks_uri": { "type": "string", "minLength": 1 },
    "registry_uri": { "type": "string", "minLength": 1 },
    "resolution_uri": { "type": "string", "minLength": 1 },
    "revocation_uri": { "type": "string", "minLength": 1 },
    "approval_uri": { "type": "string", "minLength": 1 },
    "supported_signature_algorithms": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "supported_protocols": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "supported_profiles": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "spec_version": { "type": "string", "const": "0.1" }
  },
  "additionalProperties": true
}
