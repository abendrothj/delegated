{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://delegated.dev/schemas/request-envelope.schema.json",
  "title": "TrustRequestEnvelope",
  "type": "object",
  "required": [
    "spec_version",
    "kind",
    "agent_id",
    "delegator_id",
    "audience",
    "action",
    "delegation_token"
  ],
  "properties": {
    "spec_version": { "type": "string", "const": "0.1" },
    "kind": { "type": "string", "const": "TrustRequestEnvelope" },
    "request_id": { "type": "string", "minLength": 1 },
    "profile": { "type": "string", "enum": ["developer", "oidc", "spiffe"] },
    "agent_id": { "type": "string", "minLength": 1 },
    "delegator_id": { "type": "string", "minLength": 1 },
    "audience": { "type": "string", "minLength": 1 },
    "action": { "type": "string", "minLength": 1 },
    "resource": { "type": "string", "minLength": 1 },
    "runtime_context": {
      "type": "object",
      "properties": {
        "requested_spend": { "type": "integer" },
        "spend_currency": { "type": "string", "minLength": 1 },
        "delegation_depth": { "type": "integer", "minimum": 0 },
        "target_email": { "type": "string", "minLength": 1 },
        "target_calendar_id": { "type": "string", "minLength": 1 },
        "cognitive_judge_scores_bps": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0, "maximum": 10000 }
        },
        "cognitive_challenge_pass_bps": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10000
        },
        "reputation_score_bps": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10000
        },
        "risk_challenge_passed": { "type": "boolean" },
        "extra_approval_granted": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "identity_document": {
      "$ref": "agent-identity-document.schema.json"
    },
    "delegation_token": {
      "$ref": "delegation-token.schema.json"
    }
  },
  "additionalProperties": true
}
