{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://delegated.dev/schemas/request-envelope.schema.json",
  "title": "TrustRequestEnvelope",
  "type": "object",
  "required": [
    "spec_version",
    "kind",
    "agent_id",
    "delegator_id",
    "audience",
    "action",
    "delegation_token"
  ],
  "properties": {
    "spec_version": { "type": "string", "const": "0.1" },
    "kind": { "type": "string", "const": "TrustRequestEnvelope" },
    "request_id": { "type": "string", "minLength": 1 },
    "profile": { "type": "string", "enum": ["developer", "oidc", "spiffe"] },
    "agent_id": { "type": "string", "minLength": 1 },
    "delegator_id": { "type": "string", "minLength": 1 },
    "audience": { "type": "string", "minLength": 1 },
    "action": { "type": "string", "minLength": 1 },
    "resource": { "type": "string", "minLength": 1 },
    "runtime_context": {
      "type": "object",
      "properties": {
        "requested_spend": { "type": "integer" },
        "spend_currency": { "type": "string", "minLength": 1 },
        "target_email": { "type": "string", "minLength": 1 },
        "target_calendar_id": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "identity_document": {
      "$ref": "agent-identity-document.schema.json"
    },
    "delegation_token": {
      "$ref": "delegation-token.schema.json"
    }
  },
  "additionalProperties": false
}
