{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://delegated.dev/schemas/delegation-token.schema.json",
  "title": "DelegationToken",
  "type": "object",
  "required": [
    "spec_version",
    "kind",
    "token_id",
    "issuer",
    "agent_id",
    "delegator_id",
    "owner_id",
    "audience",
    "allowed_actions",
    "issued_at",
    "expires_at",
    "nonce",
    "key_id",
    "signature_alg",
    "signature"
  ],
  "properties": {
    "spec_version": { "type": "string", "const": "0.1" },
    "kind": { "type": "string", "const": "DelegationToken" },
    "token_id": { "type": "string", "minLength": 1 },
    "issuer": { "type": "string", "minLength": 1 },
    "agent_id": { "type": "string", "minLength": 1 },
    "delegator_id": { "type": "string", "minLength": 1 },
    "owner_id": { "type": "string", "minLength": 1 },
    "audience": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "intent": { "type": "string", "minLength": 1 },
    "allowed_actions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "resource_constraints": {
      "type": "object",
      "properties": {
        "calendar_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "email_domain_allowlist": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": true
    },
    "max_spend": {
      "type": "object",
      "required": ["amount", "currency"],
      "properties": {
        "amount": { "type": "integer" },
        "currency": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "max_delegation_depth": { "type": "integer", "minimum": 0 },
    "approval_policy": { "type": "object" },
    "issued_at": { "type": "string", "format": "date-time" },
    "expires_at": { "type": "string", "format": "date-time" },
    "nonce": { "type": "string", "minLength": 1 },
    "key_id": { "type": "string", "minLength": 1 },
    "signature_alg": { "type": "string", "const": "Ed25519" },
    "signature": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": true
}
